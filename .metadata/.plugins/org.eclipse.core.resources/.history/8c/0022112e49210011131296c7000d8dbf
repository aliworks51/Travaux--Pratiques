package partie2;
import java.util.*;

public class Exercice5 {

    public static void main(String[] args) {

       
        System.out.print("Entrer la taille du tableau: ");
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        int[] T = new int[N];

        for(int i = 0 ; i < N ; i++) {
            T[i] = sc.nextInt();
                    
        }
        for(int i = 0 ; i < N ; i++) {
        	System.out.print("|"+T[i]+"|");
        }
    }
}