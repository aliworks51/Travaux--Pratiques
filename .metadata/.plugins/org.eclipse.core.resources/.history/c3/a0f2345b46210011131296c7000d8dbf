package partie2;
import java.util.*;

public class Exercice5 {

    public static void main(String[] args) {

        int i = 0;
        System.out.print("Entrer la taille du tableau: ");
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        int[] T = new int[N];

        while(i < N) {
            T[i] = sc.nextInt();
            System.out.println(T[i]);
            i++;
        }
    }
}