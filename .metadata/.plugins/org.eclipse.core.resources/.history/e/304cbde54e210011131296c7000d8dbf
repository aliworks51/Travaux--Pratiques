package partie2;
import java.util.*;
public class Exercice6 {

	public static void main(String[] args) {
		System.out.println("saisir 10 element de tableau:");
		Scanner sc = new Scanner(System.in);
		int []T = new int[10];
		for(int i = 0 ; i < 10 ; i++) {
			System.out.print("T["+i+"]=");
			T[i] = sc.nextInt();
		}
		System.out.print("demand un nombre a recherche:");
		int A = sc.nextInt();
		String s = "";
		for(int i = 0 ; i < 10 ; i++) {
			if(T[i] == A) {
				s = "element "+A+" dans position "+ ++i;
				continue;
			}else  s = "n'exest pas";
		}
		System.out.print(s);
        
	}

}
