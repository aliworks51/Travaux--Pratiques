package partie3;
import java.util.*;
public class Exercice8 {

	public static void main(String[] args) {
		System.out.println("Les element de matrice 3*3:");
		Scanner sc = new Scanner(System.in);
		int [][]M = new int[3][3];
		for(int i = 0 ; i < 3 ; i++) {
			for(int j = 0 ; j < 3 ; j++) {
				System.out.print("M["+i+"]["+j+"]=");
				M[i][j] = sc.nextInt();
			}
		}
		for(int i = 0 ; i < 3 ; i++) {
			System.out.print("|");
			for(int j = 0 ; j < 3 ; j++) {
				System.out.print(M[i][j]+" ");
				
			}
			System.out.print("|");
		}

	}

}
